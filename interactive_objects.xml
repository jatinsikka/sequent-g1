<mujoco model="interactive_objects">
  <!-- Interactive movable objects for robot manipulation tasks -->
  
  <default>
    <default class="interactive">
      <joint actuatorfrclimited="false" frictionloss="0.1" damping="1"/>
    </default>
    <geom solref="0.02 1" solimp="0.95 0.95 0.001" friction="1.5 0.5 0.1" contype="1" conaffinity="15"/>
  </default>
  
  <option>
    <flag gravity="enable"/>
  </option>
  
  <worldbody>
    
    <!-- ============================================= -->
    <!-- CONTROL PANEL - ORGANIZED LAYOUT             -->
    <!-- Centered: Buttons in a neat row              -->
    <!-- ============================================= -->
    
    <!-- Push buttons now FACE the robot (+y): cylinder axis rotated to y via euler -->
    <!-- Push Button - Red Emergency (leftmost) -->
    <!-- FIXED housing (no joint) + a separate CAP body that slides INTO the machine (-Y)
         when pressed from the front. axis="0 -1 0" so a front push gives positive displacement. -->
    <body name="push_button_red_housing" pos="-0.45 -1.85 0.8">
      <!-- contype=2 to avoid collision with panel (contype=1), but robot hands (conaffinity includes 2) can push -->
      <geom name="push_button_red_base" type="cylinder" size="0.055 0.02" euler="1.5708 0 0" rgba="0.6 0.6 0.62 1" contype="2" conaffinity="2"/>
      <body name="push_button_red" pos="0 0 0">
        <joint name="push_button_red_joint" class="interactive" type="slide" axis="0 -1 0" range="0 0.025" damping="8" stiffness="180"/>
        <geom name="push_button_red_top" type="cylinder" size="0.045 0.022" pos="0 0.03 0" euler="1.5708 0 0" rgba="0.9 0.15 0.12 1" contype="2" conaffinity="2"/>
        <inertial pos="0 0.03 0" mass="0.08" diaginertia="0.0001 0.0001 0.0001"/>
      </body>
    </body>

    <!-- Push Button - Green Start -->
    <body name="push_button_green_housing" pos="-0.15 -1.85 0.9">
      <geom name="push_button_green_base" type="cylinder" size="0.05 0.022" euler="1.5708 0 0" rgba="0.1 0.75 0.1 1" contype="2" conaffinity="2"/>
      <body name="push_button_green" pos="0 0 0">
        <joint name="push_button_green_joint" class="interactive" type="slide" axis="0 -1 0" range="0 0.03" damping="5" stiffness="100"/>
        <geom name="push_button_green_top" type="cylinder" size="0.044 0.016" pos="0 0.03 0" euler="1.5708 0 0" rgba="0.2 0.9 0.2 1" contype="2" conaffinity="2"/>
        <inertial pos="0 0.03 0" mass="0.05" diaginertia="0.00005 0.00005 0.00005"/>
      </body>
    </body>

    <!-- Push Button - Yellow Caution -->
    <body name="push_button_yellow_housing" pos="0.15 -1.85 0.9">
      <geom name="push_button_yellow_base" type="cylinder" size="0.05 0.022" euler="1.5708 0 0" rgba="0.9 0.8 0.1 1" contype="2" conaffinity="2"/>
      <body name="push_button_yellow" pos="0 0 0">
        <joint name="push_button_yellow_joint" class="interactive" type="slide" axis="0 -1 0" range="0 0.03" damping="5" stiffness="100"/>
        <geom name="push_button_yellow_top" type="cylinder" size="0.044 0.016" pos="0 0.03 0" euler="1.5708 0 0" rgba="0.95 0.9 0.2 1" contype="2" conaffinity="2"/>
        <inertial pos="0 0.03 0" mass="0.05" diaginertia="0.00005 0.00005 0.00005"/>
      </body>
    </body>

    <!-- Push Button - Blue Reset (rightmost) -->
    <body name="push_button_blue_housing" pos="0.45 -1.85 0.9">
      <geom name="push_button_blue_base" type="cylinder" size="0.05 0.022" euler="1.5708 0 0" rgba="0.1 0.1 0.8 1" contype="2" conaffinity="2"/>
      <body name="push_button_blue" pos="0 0 0">
        <joint name="push_button_blue_joint" class="interactive" type="slide" axis="0 -1 0" range="0 0.03" damping="5" stiffness="100"/>
        <geom name="push_button_blue_top" type="cylinder" size="0.044 0.016" pos="0 0.03 0" euler="1.5708 0 0" rgba="0.2 0.2 0.95 1" contype="2" conaffinity="2"/>
        <inertial pos="0 0.03 0" mass="0.05" diaginertia="0.00005 0.00005 0.00005"/>
      </body>
    </body>
    
    <!-- ============================================= -->
    <!-- LEVER (hinged handle) on the control panel    -->
    <!-- Twin of the push buttons: a handle the robot   -->
    <!-- reaches + rotates. Mounted to the RIGHT of the -->
    <!-- buttons (x=0.6) so the robot's RIGHT arm works -->
    <!-- it from the same panel stance.                 -->
    <!-- ============================================= -->
    <!-- FIXED mount bracket (no joint) on the panel face (y=-1.85). The hinge axis is
         world-X, so the handle swings in the Y-Z plane (up/down toward the robot). At
         angle 0 the handle points OUT toward the robot (+Y) at button height; rotating
         the hinge positive swings the handle DOWN through an arc (natural pull-down). Mild damping/stiffness
         so it holds position but the arm can drive it. -->
    <body name="lever_mount" pos="0.6 -1.85 0.78">
      <geom name="lever_bracket" type="box" size="0.03 0.025 0.05" pos="0 -0.02 0" rgba="0.30 0.32 0.36 1" contype="2" conaffinity="2"/>
      <geom name="lever_pivot" type="cylinder" size="0.022 0.035" pos="0 0 0" euler="0 1.5708 0" rgba="0.5 0.5 0.55 1" contype="2" conaffinity="2"/>
      <body name="lever_handle" pos="0 0 0">
        <joint name="lever_handle_joint" class="interactive" type="hinge" axis="1 0 0" range="0 1.2" damping="3" stiffness="20"/>
        <!-- shaft points OUT toward the robot (+Y) at angle 0 (grip at y~-1.69, reachable at 3.8cm).
             The robot pushes the grip UP, swinging the handle up through the arc (+angle). This is the
             ONLY direction a side-pushing arm can both reach AND drive (tested: down/up-handle throws
             put the grip out of reach). Reads as throwing a panel lever up/forward. -->
        <geom name="lever_shaft" type="capsule" fromto="0 0 0 0 0.16 0" size="0.018" rgba="0.85 0.20 0.20 1" contype="2" conaffinity="2"/>
        <!-- knob/grip at the tip: the point the hand pushes -->
        <geom name="lever_grip" type="sphere" size="0.035" pos="0 0.16 0" rgba="0.95 0.85 0.15 1" contype="2" conaffinity="2"/>
        <inertial pos="0 0.10 0" mass="0.15" diaginertia="0.001 0.001 0.001"/>
      </body>
    </body>

    <!-- ============================================= -->
    <!-- MOVABLE OBJECTS ON WORKBENCH                 -->
    <!-- ============================================= -->
    
    <!-- Screwdriver (on right table) -->
    <body name="screwdriver" pos=".6 1.2 0.74">
      <freejoint name="screwdriver_joint"/>
      <geom name="screwdriver_handle" type="box" size="0.012 0.012 0.04" rgba="0.9 0.6 0.1 1" contype="1" conaffinity="15"/>
      <geom name="screwdriver_shaft" type="box" size="0.004 0.004 0.05" pos="0 0 0.09" rgba="0.7 0.7 0.7 1" contype="1" conaffinity="15"/>
      <inertial pos="0 0 0.03" mass="0.08" diaginertia="0.0001 0.0001 0.0001"/>
    </body>
    
    <!-- Small Cube Block (on left table) -->
    <body name="block_cube" pos="1.5 -0.15 0.75">
      <freejoint name="block_cube_joint"/>
      <geom name="block_cube_geom" type="box" size="0.025 0.025 0.025" rgba="0.3 0.6 0.9 1" contype="1" conaffinity="15"/>
      <inertial pos="0 0 0" mass="0.1" diaginertia="0.0001 0.0001 0.0001"/>
    </body>
    
    <!-- Small Box (on left table) -->
    <body name="small_box" pos="1.3 -0.4 0.74">
      <freejoint name="small_box_joint"/>
      <geom name="small_box_geom" type="box" size="0.03 0.02 0.015" rgba="0.9 0.5 0.2 1" contype="1" conaffinity="15"/>
      <inertial pos="0 0 0" mass="0.08" diaginertia="0.0001 0.0001 0.0001"/>
    </body>
    
    <!-- Wrench Tool (on left table) -->
    <body name="wrench" pos="1.3 -0.25 0.74">
      <freejoint name="wrench_joint"/>
      <geom name="wrench_handle" type="box" size="0.01 0.07 0.005" rgba="0.5 0.5 0.5 1" contype="1" conaffinity="15"/>
      <geom name="wrench_head" type="cylinder" size="0.019 0.008" pos="0 0.07 0" rgba="0.5 0.5 0.5 1" contype="1" conaffinity="15"/>
      <inertial pos="0 0 0" mass="0.14" diaginertia="0.0001 0.0001 0.0001"/>
    </body>
    
    <!-- Purple Object (on right table) -->
    <body name="right_table_item2" pos="1.1 1.6 0.74">
      <freejoint name="right_table_item2_joint"/>
      <geom name="right_item2" type="box" size="0.04 0.02 0.03" rgba="0.6 0.3 0.8 1" contype="1" conaffinity="15"/>
      <inertial pos="0 0 0" mass="0.12" diaginertia="0.0001 0.0001 0.0001"/>
    </body>
    
    <!-- Battery Pack (on right table) -->
    <body name="battery_pack" pos=".65 1.6 0.74">
      <freejoint name="battery_pack_joint"/>
      <geom name="battery_body" type="box" size="0.08 0.05 0.035" rgba="0.2 0.2 0.2 1" contype="1" conaffinity="15"/>
      <geom name="battery_terminal1" type="cylinder" size="0.015 0.014" pos="0.03 0 0.038" rgba="0.8 0.7 0.2 1" contype="1" conaffinity="15"/>
      <geom name="battery_terminal2" type="cylinder" size="0.015 0.014" pos="-0.03 0 0.038" rgba="0.8 0.7 0.2 1" contype="1" conaffinity="15"/>
      <inertial pos="0 0 0" mass="0.5" diaginertia="0.0002 0.0002 0.0002"/>
    </body>
    
  </worldbody>
  
</mujoco>
